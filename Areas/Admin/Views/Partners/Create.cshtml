@model Conference_projekt.Models.Partner

@{
    ViewData["Title"] = "Dodaj partnera";
}

<div class="container" style="max-width: 720px; margin: 60px auto;">
    <h1>Dodaj partnera</h1>

@if (ViewBag.DebugErrors != null)
{
    <div style="background:#ffe6e6; color:#900; border:1px solid #c00; padding:16px; margin-bottom:20px;">
        <strong>Błędy walidacji:</strong>
        <ul>
        @foreach (var err in ViewBag.DebugErrors)
        {
            <li>@err</li>
        }
        </ul>
    </div>
}


    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div style="margin-bottom: 16px;">
            <label asp-for="Name">Nazwa</label><br>
            <input asp-for="Name" style="width: 100%; padding: 8px;">
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div style="margin-bottom: 16px;">
            <label asp-for="Description">Opis</label><br>
            <textarea asp-for="Description" rows="4" style="width: 100%; padding: 8px;"></textarea>
        </div>

        <div style="margin-bottom: 16px;">
            <label asp-for="WebsiteUrl">Strona www</label><br>
            <input asp-for="WebsiteUrl" style="width: 100%; padding: 8px;">
        </div>

        <div style="margin-bottom: 16px;">
            <label asp-for="LogoPath">Ścieżka logo</label><br>
            <input asp-for="LogoPath" placeholder="np. pics/logo/logo_blue.svg" style="width: 100%; padding: 8px;">
        </div>

        <div style="margin-bottom: 16px;">
            <label asp-for="DisplayOrder">Kolejność</label><br>
            <input asp-for="DisplayOrder" style="width: 100%; padding: 8px;">
        </div>

        <button type="submit">Zapisz</button>
        <a asp-action="Index">Anuluj</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
